# Frontend Environment Variables
# Copy this to .env.local or .env.development for local development

# API Configuration
# Backend API URL (must match backend PORT and CORS_ORIGIN)
VITE_API_URL=http://localhost:3000/api

# Development mode  
VITE_DEV_MODE=true

# App configuration
VITE_APP_NAME=HVKTCNAN Schedule Management
VITE_APP_VERSION=1.0.0
