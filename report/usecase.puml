@startuml usecase_overview
title Biểu đồ Use Case Tổng Quan - Hệ thống Quản lý Lịch Công tác và Trực Ban

skinparam backgroundColor white
skinparam shadowing false
skinparam roundcorner 12

skinparam actorStyle awesome
skinparam actorBorderColor black
skinparam actorBackgroundColor white

skinparam usecaseBorderColor black
skinparam usecaseBackgroundColor white
skinparam ArrowColor #333333

skinparam packageBorderColor black
skinparam packageBackgroundColor white

skinparam defaultTextAlignment center
skinparam fontSize 13

top to bottom direction

' ================= Actors =================
actor "Cán bộ" as officer
actor "Phó / Trưởng phòng" as manager
actor "Giám đốc /\nPhó giám đốc" as admin
actor "Quản trị viên\nhệ thống" as superadmin
actor "Phó / Trưởng phòng HC,\nĐội xe, Đội bệnh xá" as dutyMgr

' ===== Hierarchy =====
manager --|> officer
admin --|> manager
superadmin --|> admin
dutyMgr --|> manager

rectangle "Hệ thống Quản lý Lịch Công tác và Trực Ban" {

    together {

        package "Xác thực" {
            usecase "UC01\nĐăng nhập" as UC01
        }

        package "Lịch & Công việc" {
            usecase "UC03\nQL Lịch Công tác" as UC03
            usecase "UC04\nQL Lịch Trực ban" as UC04
            usecase "UC05\nLịch của Tôi" as UC05
            usecase "UC06\nÝ kiến Trực ban" as UC06
            usecase "UC11\nQL Xin Nghỉ" as UC11
        }

        package "Quản trị hệ thống" {
            usecase "UC02\nQL Cán bộ" as UC02
            usecase "UC09\nQL Ngày lễ" as UC09
            usecase "UC10\nQL Phòng ban" as UC10
            usecase "UC12\nPhân quyền Lịch" as UC12
        }

        package "Tiện ích" {
            usecase "UC07\nThông báo" as UC07
            usecase "UC08\nXuất dữ liệu" as UC08
        }
    }
}

' ================= Connections =================

officer --> UC01
officer --> UC05
officer --> UC06
officer --> UC07
officer --> UC08
officer --> UC11

manager --> UC03
manager --> UC04

admin --> UC02
admin --> UC09
admin --> UC10

superadmin --> UC12

dutyMgr --> UC04

@enduml

@startuml usecase_auth
title Nhóm Use Case Xác thực và Quản lý Phiên Đăng nhập

skinparam backgroundColor white
skinparam usecaseBorderColor black
skinparam actorBorderColor black
skinparam ArrowColor black
skinparam defaultTextAlignment center
skinparam fontSize 11

left to right direction

actor "Quản trị viên hệ thống" as superadmin
actor "Giám đốc/ Phó giám đốc" as admin
actor "Phó/ Trưởng phòng" as manager
actor "cán bộ" as officer

rectangle "Xác thực và Quản lý Phiên" {
    usecase "UC01: Đăng nhập" as UC01
    usecase "Khôi phục Phiên" as UC01_restore
    usecase "Đăng xuất" as UC01_logout
}


superadmin --> UC01
admin --> UC01
manager --> UC01
officer --> UC01

UC01 <|-- UC01_restore : extend
UC01 <|-- UC01_logout : extend
@enduml

@startuml usecase_officers
title Nhóm Use Case Quản lý Hồ sơ Cán bộ

skinparam backgroundColor white
skinparam usecaseBorderColor black
skinparam actorBorderColor black
skinparam ArrowColor black
skinparam defaultTextAlignment center
skinparam fontSize 11

left to right direction

actor "Quản trị viên hệ thống" as superadmin
actor "Giám đốc/ Phó giám đốc" as admin
actor "Phó/ Trưởng phòng" as manager


rectangle "Quản lý Hồ sơ Cán bộ" {
    usecase "UC02: Quản lý Cán bộ" as UC02
    usecase "Xem Danh sách Cán bộ" as UC02_view
    usecase "Thêm/Sửa/Xóa Cán bộ\n(Superadmin)" as UC02_crud
    usecase "Cấp/Thu hồi Quyền Quản lý\n(Admin)" as UC02_permission
    usecase "Tìm kiếm & Lọc" as UC02_search
}

superadmin --> UC02
admin --> UC02
manager --> UC02

UC02 *-- UC02_view : include
UC02 *-- UC02_crud : include
UC02 *-- UC02_permission : include
UC02_view <|-- UC02_search : extend
